<Window x:Class="CcMiniWpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CcMiniWpf.ViewModels"
        xmlns:models="clr-namespace:CcMiniWpf.Models"
        xmlns:conv="clr-namespace:CcMiniWpf.Views.Converters"
        Title="cc-mini" Width="900" Height="700" MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <conv:EnumToVisibilityConverter x:Key="EnumVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>    <!-- 顶部状态栏 -->
            <RowDefinition Height="*"/>     <!-- 聊天区域 -->
            <RowDefinition Height="Auto"/>  <!-- 输入区域 -->
        </Grid.RowDefinitions>

        <!-- ═══ 顶部状态栏 ═══ -->
        <Border Grid.Row="0" Background="{StaticResource MantleBrush}" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 标题 -->
                <TextBlock Grid.Column="0" Text="cc-mini" FontWeight="Bold" FontSize="16"
                           Foreground="{StaticResource BlueBrush}" VerticalAlignment="Center"/>

                <!-- 工作目录按钮 -->
                <Button Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"
                        Style="{StaticResource SecondaryButton}" Padding="8,4"
                        Command="{Binding SelectWorkingDirectoryCommand}"
                        ToolTip="{Binding WorkingDirectory}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁 " FontSize="12"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextBrush}"
                                   MaxWidth="200" TextTrimming="CharacterEllipsis"
                                   Text="{Binding WorkingDirectory}"/>
                    </StackPanel>
                </Button>

                <!-- 状态文本 -->
                <TextBlock Grid.Column="2" Text="{Binding StatusText}" Margin="12,0,0,0"
                           Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <!-- 自动批准开关 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <TextBlock Text="自动批准" FontSize="12" VerticalAlignment="Center"
                               Foreground="{StaticResource SubtextBrush}" Margin="0,0,6,0"/>
                    <CheckBox IsChecked="{Binding AutoApprove}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Token 计数 -->
                <TextBlock Grid.Column="4" Text="{Binding CostText}" Margin="8,0"
                           Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center"
                           FontSize="12"/>

                <!-- 状态指示灯 -->
                <Border Grid.Column="5" Width="8" Height="8" CornerRadius="4" Margin="4,0"
                        Background="{StaticResource GreenBrush}" VerticalAlignment="Center"
                        Visibility="{Binding IsProcessing, Converter={StaticResource InvBoolVis}}"/>
                <Border Grid.Column="5" Width="8" Height="8" CornerRadius="4" Margin="4,0"
                        Background="{StaticResource YellowBrush}" VerticalAlignment="Center"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BoolVis}}"/>
            </Grid>
        </Border>

        <!-- ═══ 聊天区域（左右分栏） ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ── 左侧：对话文本流 ── -->
            <ScrollViewer Grid.Column="0" x:Name="ChatScroller"
                          VerticalScrollBarVisibility="Auto" Padding="0,8"
                          ScrollChanged="ChatScroller_ScrollChanged">
                <ItemsControl x:Name="ChatItemsControl" ItemsSource="{Binding Messages}" Margin="0,0,0,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ChatMessage}">
                            <Grid Margin="0,2">
                                <!-- 用户消息 -->
                                <Border Style="{StaticResource UserBubble}"
                                        Visibility="{Binding Role, Converter={StaticResource EnumVis}, ConverterParameter=User}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TaskIndex, StringFormat='#{0}'}"
                                                   Foreground="{StaticResource OverlayBrush}"
                                                   FontSize="11" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- 助手消息 -->
                                <Border Style="{StaticResource AssistantBubble}"
                                        Visibility="{Binding Role, Converter={StaticResource EnumVis}, ConverterParameter=Assistant}">
                                    <StackPanel>
                                        <!-- 文本内容 -->
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextBrush}"/>

                                        <!-- 工具锚点引用标记（紧凑横排） -->
                                        <ItemsControl ItemsSource="{Binding ToolCalls}" Margin="0,4,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:ToolCallInfo}">
                                                    <Border Style="{StaticResource ToolAnchorBorder}"
                                                            MouseLeftButtonDown="ToolAnchor_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontSize="11" Foreground="{StaticResource BlueBrush}" FontWeight="SemiBold">
                                                                <Run Text="&#x1F4CE;"/><Run Text="{Binding GlobalIndex, Mode=OneWay}"/>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding Name}" FontSize="11" Margin="4,0,0,0"
                                                                       Foreground="{StaticResource SubtextBrush}"/>
                                                            <!-- 状态指示 -->
                                                            <TextBlock Text=" &#x25CF;" FontSize="8" Margin="4,0,0,0"
                                                                       Foreground="{StaticResource YellowBrush}"
                                                                       Visibility="{Binding Status, Converter={StaticResource EnumVis}, ConverterParameter=Executing}"/>
                                                            <TextBlock Text=" &#x2713;" FontSize="10" Margin="2,0,0,0"
                                                                       Foreground="{StaticResource GreenBrush}"
                                                                       Visibility="{Binding Status, Converter={StaticResource EnumVis}, ConverterParameter=Complete}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 流式指示 -->
                                        <TextBlock Text="&#x258C;" Foreground="{StaticResource BlueBrush}" FontSize="16"
                                                   Visibility="{Binding Status, Converter={StaticResource EnumVis}, ConverterParameter=Streaming}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ── 右侧：工具卡片面板 ── -->
            <Border Grid.Column="1" Width="320"
                    Background="{StaticResource MantleBrush}"
                    BorderBrush="{StaticResource Surface1Brush}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding HasAnyToolCalls, Converter={StaticResource BoolVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 面板标题 -->
                    <Border Grid.Row="0" Style="{StaticResource ToolPanelHeader}">
                        <TextBlock Text="&#x2699; &#x5DE5;&#x5177;&#x8C03;&#x7528;" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource SubtextBrush}"/>
                    </Border>

                    <!-- 工具卡片列表 -->
                    <ScrollViewer Grid.Row="1" x:Name="ToolScroller"
                                  VerticalScrollBarVisibility="Auto" Padding="8,4"
                                  ScrollChanged="ToolScroller_ScrollChanged">
                        <ItemsControl x:Name="ToolItemsControl" ItemsSource="{Binding AllToolCalls}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ToolCallInfo}">
                                    <Border x:Name="CardBorder" Style="{StaticResource ToolCallBorder}"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="ToolCard_Click">
                                        <StackPanel>
                                            <!-- 任务标识 + 工具名 + 编号 -->
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="{StaticResource Surface1Brush}"
                                                        CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding TaskIndex, StringFormat='#{0}'}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource PeachBrush}"/>
                                                </Border>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{StaticResource BlueBrush}">
                                                    <Run Text="&#x2699; "/><Run Text="{Binding Name, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding GlobalIndex, StringFormat=' &#x1F4CE;{0}'}"
                                                           FontSize="11" Margin="4,0,0,0"
                                                           Foreground="{StaticResource OverlayBrush}"/>
                                            </StackPanel>

                                            <!-- Activity + 状态 -->
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Activity}"
                                                           Foreground="{StaticResource SubtextBrush}"
                                                           FontSize="12"/>
                                                <TextBlock Text=" &#x25CF;" FontSize="10" Margin="6,0,0,0"
                                                           Foreground="{StaticResource YellowBrush}"
                                                           Visibility="{Binding Status, Converter={StaticResource EnumVis}, ConverterParameter=Executing}"/>
                                                <TextBlock Text=" &#x2713;" FontSize="12" Margin="4,0,0,0"
                                                           Foreground="{StaticResource GreenBrush}"
                                                           Visibility="{Binding Status, Converter={StaticResource EnumVis}, ConverterParameter=Complete}"/>
                                            </StackPanel>

                                            <!-- 输入摘要 -->
                                            <TextBlock Text="{Binding InputSummary}" TextWrapping="Wrap"
                                                       Foreground="{StaticResource OverlayBrush}"
                                                       FontSize="12" Margin="0,4,0,0"
                                                       MaxHeight="60" TextTrimming="CharacterEllipsis"/>

                                            <!-- 结果（可折叠） -->
                                            <Expander IsExpanded="{Binding IsExpanded}"
                                                      Margin="0,4,0,0"
                                                      Visibility="{Binding Status, Converter={StaticResource EnumVis}, ConverterParameter=Complete}">
                                                <Expander.Header>
                                                    <TextBlock Text="&#x67E5;&#x770B;&#x7ED3;&#x679C;" FontSize="12"
                                                               Foreground="{StaticResource SubtextBrush}"/>
                                                </Expander.Header>
                                                <TextBlock Text="{Binding ResultContent}" TextWrapping="Wrap"
                                                           Foreground="{StaticResource SubtextBrush}"
                                                           FontSize="12" FontFamily="Cascadia Code, Consolas"
                                                           MaxHeight="200"/>
                                            </Expander>

                                            <!-- 错误标记 -->
                                            <TextBlock Text="&#x2717; &#x6267;&#x884C;&#x51FA;&#x9519;" Foreground="{StaticResource RedBrush}"
                                                       FontSize="12" Margin="0,2,0,0"
                                                       Visibility="{Binding IsError, Converter={StaticResource BoolVis}}"/>
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                            <Setter TargetName="CardBorder" Property="BorderBrush"
                                                    Value="{StaticResource PeachBrush}"/>
                                            <Setter TargetName="CardBorder" Property="BorderThickness"
                                                    Value="2,1,1,1"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ 底部输入区 ═══ -->
        <Border Grid.Row="2" Background="{StaticResource MantleBrush}" Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 命令补全弹出列表（输入框上方） -->
                <Popup Grid.Row="0" Grid.Column="0" x:Name="CommandPopup"
                       IsOpen="{Binding IsCommandPopupOpen}"
                       PlacementTarget="{Binding ElementName=InputBox}"
                       Placement="Top" StaysOpen="True"
                       AllowsTransparency="True" PopupAnimation="Fade">
                    <Border Background="{StaticResource Surface0Brush}"
                            BorderBrush="{StaticResource Surface1Brush}"
                            BorderThickness="1" CornerRadius="8"
                            MaxHeight="260" MinWidth="320"
                            Padding="4">
                        <ListBox x:Name="CommandListBox"
                                 ItemsSource="{Binding FilteredCommands}"
                                 SelectedIndex="{Binding SelectedCommandIndex, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 MouseDoubleClick="CommandListBox_MouseDoubleClick">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10,6"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                        CornerRadius="4" Background="Transparent">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource Surface1Brush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource Surface1Brush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SlashCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource BlueBrush}"
                                                   Text="{Binding DisplayText}" MinWidth="160"/>
                                        <TextBlock Grid.Column="1" FontSize="12" Margin="12,0,0,0"
                                                   Foreground="{StaticResource SubtextBrush}"
                                                   Text="{Binding Description}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>

                <!-- 输入框：支持多行（Shift+Enter换行，Enter发送） -->
                <TextBox Grid.Row="1" Grid.Column="0" x:Name="InputBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBox}" MaxHeight="150" MinHeight="36"
                         PreviewKeyDown="InputBox_PreviewKeyDown"
                         SpellCheck.IsEnabled="False"/>

                <Button Grid.Row="1" Grid.Column="1" Content="发送" Margin="8,0,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SendCommand}" VerticalAlignment="Bottom"/>

                <Button Grid.Row="1" Grid.Column="2" Content="中断" Margin="6,0,0,0"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding AbortCommand}"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BoolVis}}"
                        VerticalAlignment="Bottom"/>

                <!-- 提示行 -->
                <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Margin="4,4,0,0"
                           FontSize="11" Foreground="{StaticResource OverlayBrush}">
                    <Run Text="Enter 发送 · Shift+Enter 换行 · 输入 / 查看命令"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
